	#		if statement not working, does not create $LogDir.
	#		Have the sanity check root and use sudo if needed (will require chown/chmod as new folder will be root only).
	#
	if [ ! -d ${LogDir} ]
	then
    	mkdir -p ${LogDir}
	fi

